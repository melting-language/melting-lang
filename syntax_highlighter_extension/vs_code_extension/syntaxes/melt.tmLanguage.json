{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Melt",
  "scopeName": "source.melt",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#method-call" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.melt",
          "match": "//.*$",
          "comment": "Line comment"
        },
        {
          "name": "comment.block.melt",
          "begin": "/\\*",
          "end": "\\*/",
          "comment": "Block comment"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.melt",
          "match": "\\b(if|else|while|return|try|catch|throw)\\b"
        },
        {
          "name": "keyword.declaration.melt",
          "match": "\\b(let|class|method|import)\\b"
        },
        {
          "name": "keyword.other.melt",
          "match": "\\b(print|this)\\b"
        },
        {
          "name": "constant.language.boolean.melt",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.melt",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.melt",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.melt",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.melt",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.melt",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.comparison.melt",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.arithmetic.melt",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.access.melt",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.melt",
          "match": ",|;"
        },
        {
          "name": "punctuation.definition.group.melt",
          "match": "\\(|\\)|\\{|\\}"
        }
      ]
    },
    "method-call": {
      "patterns": [
        {
          "name": "entity.name.function.melt",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "comment": "Function/method name before ("
        }
      ]
    }
  }
}
